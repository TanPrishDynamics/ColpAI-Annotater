# Copy to /opt/colpai/colpai.env on the server and `chmod 600` it.
# Referenced by the systemd unit (EnvironmentFile=).

# Run in production mode (enables secure cookies + the secret-key guard).
COLPAI_CONFIG=prod

# REQUIRED. Generate a strong value once and keep it secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
COLPAI_SECRET_KEY=replace-with-a-64-char-hex-secret

# Optional: where gunicorn listens (nginx proxies to this). Default 127.0.0.1:8000
# COLPAI_BIND=127.0.0.1:8000

# Optional: number of gunicorn workers. Default = 2*CPU + 1
# COLPAI_WORKERS=3

# Optional: move off SQLite to Postgres for a larger team.
# COLPAI_DATABASE_URI=postgresql+psycopg://colpai:password@localhost/colpai
