# ColpAi-Annotater — environment variable template
# Copy to `.env` and fill in real values:  cp .env.example .env
# `.env` is gitignored; never commit real secrets.
#
# In production, copy this to the server (e.g. /opt/colpai/colpai.env),
# `chmod 600` it, and point the systemd unit's EnvironmentFile= at it.

# ---- Core app ----
# Which config to load: dev | test | prod  (default: dev)
COLPAI_CONFIG=dev

# Flask session/signing key. REQUIRED in prod — the app refuses to boot without it.
# Generate a strong one:  python -c "import secrets; print(secrets.token_hex(32))"
COLPAI_SECRET_KEY=dev-secret-change-me-in-prod

# Database connection. Defaults to local SQLite at data/annotations.db if unset.
# SQLite:    sqlite:////absolute/path/to/annotations.db
# Postgres:  postgresql+psycopg://user:password@host:5432/colpai
COLPAI_DATABASE_URI=sqlite:///data/annotations.db

# ---- Uploads ----
# Directory where uploaded/ingested images are stored (default: data/uploads)
COLPAI_UPLOAD_DIR=data/uploads

# Max size of a single upload request, in MB (default: 200)
COLPAI_MAX_UPLOAD_MB=200

# ---- Gunicorn / deployment (only used by the prod server) ----
# Address to bind (default: 127.0.0.1:8000)
COLPAI_BIND=127.0.0.1:8000

# Number of worker processes (default: auto from CPU count)
COLPAI_WORKERS=4

# Worker timeout in seconds (default: 300)
COLPAI_TIMEOUT=300

# Log level: debug | info | warning | error (default: info)
COLPAI_LOGLEVEL=info
